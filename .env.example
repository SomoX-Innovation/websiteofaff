# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=WellwetX

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=Wellwetx_bot
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_ANNOUNCE_CHAT_ID_VIDEOS=
TELEGRAM_ANNOUNCE_CHAT_ID_STORIES=

# Cron auth for /api/cron/telegram-autopost
CRON_SECRET=

# Postgres connection string (Supabase) for durable Chat SDK bot state
POSTGRES_URL=
